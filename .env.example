BACKEND_API_URL=https://inference.api.libertai.io
BACKEND_SECRET_TOKEN=__ADMIN__SECRET__TOKEN__
MODELS_CONFIG=/data/models.json

# Telegram alerting
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TOPIC_ID=

# -- Logging --
LOG_LEVEL=DEBUG

PRIVATE_KEY=

# x402
X402_API_KEY=
X402_SERVER_WALLET_ADDRESS=
X402_WALLET_ADDRESS=
THIRDWEB_SECRET_KEY=
THIRDWEB_VAULT_ACCESS_TOKEN=

PUBLIC_BASE_URL=https://api.libertai.io

# Aleph credits
ALEPH_SENDER_PRIVATE_KEY=

# Redis (shared state for multi-container deployments)
REDIS_URL=redis://redis:6379/0

# Search service
SEARCH_SERVICE_URL=https://search.libertai.io

# Chat API key limits (0 disables a limit)
CHAT_RATE_LIMIT_PER_MINUTE=30
CHAT_RATE_LIMIT_PER_DAY=1500
CHAT_SEARCH_RATE_LIMIT_PER_DAY=50
